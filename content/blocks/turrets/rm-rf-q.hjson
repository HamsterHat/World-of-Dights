type: PowerTurret
size: 2
health: 64
range: 128
shootSound: rm-shoot
chargeSound: rm-charge
shootEffect: shootBig
rotateSpeed: 0
reload: 170
recoil: 0
shootCone: 360
shootY: 0
linearWarmup: true
alwaysShooting: true
minWarmup: 1
shootWarmupSpeed: 0.0016666666
cooldownTime: 160


rotate: false
quickRotate: false

shoot: {
	type: ShootSpread
	shots: 1
}

shootType: {
	type: BulletType
	lifetime: 0
	absorbable: false
	hittable: false
	despawnEffect: none
	collides: false
	killShooter: true
	status: remove
	splashDamage: 9999999999999999999999999999999999
	splashDamageRadius: 128
}

destroyBullet: {
    type: BulletType
    speed: 0
    lifetime: 0
    splashDamage: 999
    splashDamageRadius: 128
    instantDisappear: true
    hitEffect: none
    despawnEffect: none
    hittable: false
    absorbable: false
    collides: false
	status: glitched
}

destroyEffect: {
  type: MultiEffect
  effects: [
	{
      type: ParticleEffect
      particles: 1
      lifetime: 15
      length: 0
      colorFrom: 00ffff
      colorTo: 00ff00
      sizeFrom: 128
	  sizeTo: 128
    }
	{
      type: ParticleEffect
      particles: 1
      lifetime: 15
	  startDelay: 15
      length: 0
      colorFrom: 00ff00
      colorTo: 0000ff
      sizeFrom: 128
	  sizeTo: 128
    }
	{
      type: ParticleEffect
      particles: 1
      lifetime: 15
	  startDelay: 30
      length: 0
      colorFrom: 0000ff
      colorTo: 00ffff
      sizeFrom: 128
	  sizeTo: 0
    }
    {
      type: WaveEffect
      lifetime: 90
      sizeTo: 128
	  sizeFrom: 128
	  strokeFrom: 8
	  strokeTo: 8
      colorFrom: 00ffff
      colorTo: 002222
    }
	{
      type: WaveEffect
      lifetime: 60
	  startDelay: 90
      sizeTo: 0
	  sizeFrom: 128
	  strokeFrom: 8
	  strokeTo: 0
      colorFrom: 002222
      colorTo: 00ffff
    }
  ]
}

